# OpenClaw Marketing Hub - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Demo Mode (true = no gateway needed, simulated activity)
DEMO_MODE=true

# OpenClaw Gateway (required when DEMO_MODE=false)
GATEWAY_URL=ws://127.0.0.1:18789
GATEWAY_TOKEN=

# Voice Configuration (Cartesia via chat-proxy)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CHAT_PROXY_URL=http://127.0.0.1:8080

# Late API (for social media posting)
LATE_API_KEY=
LATE_API_BASE=https://getlate.dev/api/v1

# Weather Location
WEATHER_LOCATION=Barcelona,Spain

# Database (auto-created in data/ directory)
DATABASE_PATH=./data/marketing-hub.db

# Multi-Company Settings
DEFAULT_COMPANY=example
MAX_COMPANIES=5
